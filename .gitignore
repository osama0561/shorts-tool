.env
.claude/settings.local.json
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Runtime artifacts — keep the directories but not their contents
inputs/*
working/*
outputs/*
logs/*
!inputs/.gitkeep
!working/.gitkeep
!outputs/.gitkeep
!logs/.gitkeep

# Local SQLite database
*.db
*.db-journal

# Test-data video/audio content (personal material — do not commit)
test_data/*
!test_data/.gitkeep

# Vendored third-party sources (re-fetch via scripts/setup_pot_provider.sh)
vendor/
