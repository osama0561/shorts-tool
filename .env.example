# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model IDs (overridable for experimentation)
GEMINI_REASONING_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-pro

# Working paths — all relative to project root by default
INPUTS_DIR=inputs
WORKING_DIR=working
OUTPUTS_DIR=outputs
LOGOS_DIR=logos

# SQLite database file (relative to project root)
DB_PATH=shorts.db

# Logging
LOG_LEVEL=INFO

# --- YouTube download options ---
# YouTube increasingly blocks datacenter IPs with "confirm you're not a bot".
# Workaround: export cookies from a logged-in browser (Netscape format) and
# point COOKIES_FILE at them. Leave blank to skip.
#   Chrome/Firefox extension: "Get cookies.txt LOCALLY"
#   Save the file into ./inputs/cookies.txt (or anywhere you prefer)
COOKIES_FILE=

# Alternatively, if you are running this locally and have a browser installed,
# yt-dlp can pull cookies directly. Format: "<browser>[:<profile>]"
# Examples: chrome, firefox, brave, chrome:Default
COOKIES_FROM_BROWSER=
